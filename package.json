{
  "name": "deck",
  "version": "0.1.7",
  "private": true,
  "type": "module",
  "scripts": {
    "deck": "bun run --cwd apps/cli deck",
    "build": "bun run scripts/build-binaries.ts",
    "build:dry-run": "bun run scripts/build-binaries.ts --dry-run",
    "deck:run": "DECK_DEBUG=1 bun run build:dry-run && DECK_DEBUG=1 ./dist/cli/deck",
    "test": "bun test"
  },
  "bin": {
    "deck": "./dist/cli/deck"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "latest",
    "typescript": "latest"
  },
  "dependencies": {
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
